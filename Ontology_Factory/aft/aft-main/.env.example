PYTHONPATH=src

ONTOLOGY_AUDIT_RUN_ROOT=artifacts/runs
ONTOLOGY_AUDIT_CHECKPOINT_PATH=artifacts/checkpoints/audit_sessions.sqlite3
ONTOLOGY_AUDIT_INTERRUPT_ON_HUMAN=true
ONTOLOGY_AUDIT_BACKEND_TIMEOUT_SECONDS=5.0

ONTOLOGY_AUDIT_QDRANT_ENABLED=true
ONTOLOGY_AUDIT_QDRANT_MODE=server
ONTOLOGY_AUDIT_QDRANT_PATH=artifacts/qdrant
ONTOLOGY_AUDIT_QDRANT_URL=http://qdrant:6333
ONTOLOGY_AUDIT_QDRANT_API_KEY=
ONTOLOGY_AUDIT_QDRANT_COLLECTION=ontology_audit_chunks_v2
ONTOLOGY_AUDIT_QDRANT_UPLOAD_CHUNK_SIZE=1000
ONTOLOGY_AUDIT_QDRANT_UPLOAD_OVERLAP_SIZE=200

ONTOLOGY_AUDIT_RAG_EMBEDDING_PROVIDER=openai
ONTOLOGY_AUDIT_RAG_EMBEDDING_MODEL=openai/text-embedding-3-small
ONTOLOGY_AUDIT_RAG_EMBEDDING_DIMENSIONS=1536
ONTOLOGY_AUDIT_RAG_EMBEDDING_API_KEY=
ONTOLOGY_AUDIT_RAG_EMBEDDING_BASE_URL=
ONTOLOGY_AUDIT_RAG_CHUNK_TOKENS=400
ONTOLOGY_AUDIT_RAG_CHUNK_OVERLAP_TOKENS=80
ONTOLOGY_AUDIT_RAG_MAX_CHUNK_TOKENS=600
ONTOLOGY_AUDIT_RAG_CANDIDATE_POOL=40
ONTOLOGY_AUDIT_RAG_TOP_K=8
ONTOLOGY_AUDIT_RAG_MAX_CONTEXT_CHUNKS=6
ONTOLOGY_AUDIT_RAG_ENABLE_GRAPH_CONTEXT=true

ONTOLOGY_AUDIT_NEO4J_ENABLED=true
ONTOLOGY_AUDIT_NEO4J_URI=bolt://neo4j:7687
ONTOLOGY_AUDIT_NEO4J_USERNAME=neo4j
ONTOLOGY_AUDIT_NEO4J_PASSWORD=password
ONTOLOGY_AUDIT_NEO4J_DATABASE=neo4j

ONTOLOGY_AUDIT_LLM_ENABLED=false
ONTOLOGY_AUDIT_LLM_PROVIDER=pydantic-ai
ONTOLOGY_AUDIT_LLM_MODEL=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Agent System Prompts (Optional Overrides)
# These allow keeping agent logic/prompts out of the source code (and GitHub).
# ONTOLOGY_AUDIT_PROMPT_GITHUB_SCOPE_PLANNER=...
# ONTOLOGY_AUDIT_PROMPT_GITHUB_CORRECTNESS=...
# ONTOLOGY_AUDIT_PROMPT_GITHUB_RISK_REGRESSION=...
# ONTOLOGY_AUDIT_PROMPT_GITHUB_SECURITY=...
# ONTOLOGY_AUDIT_PROMPT_GITHUB_TEST_COVERAGE=...
# ONTOLOGY_AUDIT_PROMPT_GITHUB_JUDGE_MERGE=...
# ONTOLOGY_AUDIT_PROMPT_QA_ANSWER=...
# ONTOLOGY_AUDIT_PROMPT_QA_RETRIEVAL_DECISION=...
# ONTOLOGY_AUDIT_PROMPT_QA_CLASSIFY_INTENT=...
# ONTOLOGY_AUDIT_PROMPT_QA_QUERY_REWRITE=...
# ONTOLOGY_AUDIT_PROMPT_DOC_CLAIM_EXTRACTION=...
# ONTOLOGY_AUDIT_PROMPT_HUMAN_CARD_ENHANCEMENT=...
# ONTOLOGY_AUDIT_PROMPT_REPAIR_SUGGESTION=...
