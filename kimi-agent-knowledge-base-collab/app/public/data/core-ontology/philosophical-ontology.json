{
  "metadata": {
    "title": "哲学本体论核心框架",
    "created_by": "哲学本体论专家",
    "version": "1.0",
    "description": "基于西方哲学传统构建的本体论核心概念体系"
  },
  "core_domains": {
    "存在论_ontology_of_being": {
      "description": "研究存在本身的基本问题",
      "concepts": {
        "存在_being": {
          "definition": "一切可言说、可思考者的最基本规定",
          "types": [
            "现实存在",
            "可能存在",
            "必然存在",
            "偶然存在"
          ],
          "references": [
            "巴门尼德",
            "亚里士多德《形而上学》",
            "海德格尔《存在与时间》"
          ]
        },
        "实体_substance": {
          "definition": "独立自存、不依赖于其他事物而存在的东西",
          "types": [
            "初级实体（个体）",
            "次级实体（种属）"
          ],
          "properties": [
            "独立性",
            "统一性",
            "持续性"
          ]
        },
        "个体_individual": {
          "definition": "具体的、独特的、不可重复的存在者",
          "examples": [
            "这个苹果",
            "苏格拉底",
            "地球"
          ],
          "criteria": [
            "时空定位",
            "特定属性组合",
            "身份同一性"
          ]
        },
        "共相_universal": {
          "definition": "可被多个个体分享的共同性质或形式",
          "problem": "共相问题（唯名论 vs 实在论）",
          "positions": [
            "极端唯名论",
            "概念论",
            "温和实在论",
            "极端实在论"
          ]
        }
      }
    },
    "范畴论_category_theory": {
      "description": "对存在的基本类型和范畴的分类研究",
      "systems": {
        "亚里士多德范畴": {
          "categories": [
            "实体（ousia）- 主体",
            "量（poson）- 多少、大小",
            "质（poion）- 性质、特征",
            "关系（pros ti）- 相对于他物",
            "地点（pou）- 空间位置",
            "时间（pote）- 时间位置",
            "姿态（keisthai）- 坐、躺等",
            "具有（echein）- 穿、戴等",
            "动作（poiein）- 主动行为",
            "遭受（paschein）- 被动承受"
          ],
          "significance": "第一个系统的范畴分类，影响深远"
        },
        "康德范畴": {
          "quantity": [
            "单一性",
            "复多性",
            "全体性"
          ],
          "quality": [
            "实在性",
            "否定性",
            "限定性"
          ],
          "relation": [
            "依存性与自存性",
            "因果性与隶属性",
            "协同性"
          ],
          "modality": [
            "可能性-不可能性",
            "存有-非有",
            "必然性-偶然性"
          ],
          "significance": "先验范畴，构成经验的先天条件"
        },
        "现代范畴论": {
          "approaches": [
            "形式化范畴",
            "语义范畴",
            "认知范畴"
          ],
          "applications": [
            "计算机科学",
            "语言学",
            "认知科学"
          ]
        }
      }
    },
    "属性论_theory_of_properties": {
      "description": "研究事物属性的本质和分类",
      "property_types": {
        "本质属性": {
          "definition": "一个事物之所以为该事物的必要属性",
          "examples": [
            "理性是人的本质属性",
            "三角形内角和180度"
          ],
          "characteristics": [
            "必然性",
            "恒常性",
            "定义性"
          ]
        },
        "偶然属性": {
          "definition": "事物可以拥有也可以不拥有的属性",
          "examples": [
            "苏格拉底是秃头",
            "苹果是红色的"
          ],
          "characteristics": [
            "可变性",
            "非定义性"
          ]
        },
        "关系属性": {
          "definition": "事物相对于其他事物而具有的属性",
          "types": [
            "空间关系",
            "时间关系",
            "因果关系",
            "相似关系"
          ],
          "nature": "内在关系 vs 外在关系"
        },
        "倾向性属性": {
          "definition": "在特定条件下才会显现的潜在属性",
          "examples": [
            "可溶性",
            "可燃性",
            "脆弱性"
          ],
          "ontology": "关于可能性的实在"
        }
      }
    },
    "关系论_theory_of_relations": {
      "description": "研究事物间关系的本体论地位",
      "relation_types": {
        "内部关系": {
          "definition": "关系项的本质包含关系本身",
          "examples": [
            "部分与整体",
            "性质与实体"
          ],
          "philosophers": [
            "黑格尔",
            "布拉德雷"
          ]
        },
        "外部关系": {
          "definition": "关系项的本质独立于关系",
          "examples": [
            "空间邻近",
            "时间先后"
          ],
          "philosophers": [
            "摩尔",
            "罗素"
          ]
        },
        "因果关系": {
          "definition": "一个事件引起另一个事件的关系",
          "theories": [
            "规律论",
            "反事实理论",
            "传递理论",
            "干预主义"
          ],
          "problems": [
            "休谟问题",
            "因果方向",
            "因果选择"
          ]
        },
        "部分-整体关系": {
          "definition": "mereology，研究部分与整体的系统理论",
          "axioms": [
            "自反性",
            "反对称性",
            "传递性"
          ],
          "applications": [
            "形式本体论",
            "计算机科学",
            "生物学"
          ]
        }
      }
    },
    "过程与变化": {
      "description": "研究运动、变化、生成的本体论",
      "concepts": {
        "变化_change": {
          "types": [
            "实体变化（生成与毁灭）",
            "性质变化（质变）",
            "量变化（增减）",
            "位置变化（运动）"
          ],
          "paradoxes": [
            "芝诺悖论",
            "飞矢不动"
          ]
        },
        "时间_time": {
          "nature": [
            "A理论（动态）",
            "B理论（静态）"
          ],
          "topology": [
            "线性",
            "分支",
            "循环"
          ],
          "ontology": [
            "现在主义",
            "永恒主义",
            "增长块理论"
          ]
        },
        "空间_space": {
          "nature": [
            "绝对空间（牛顿）",
            "相对空间（莱布尼茨）",
            "关系论"
          ],
          "geometry": [
            "欧几里得",
            "非欧几何",
            "流形"
          ]
        },
        "过程_process": {
          "definition": "作为基本实在的事件序列",
          "philosophers": [
            "怀特海（过程哲学）",
            "柏格森（绵延）"
          ],
          "priority": "过程优先 vs 实体优先"
        }
      }
    },
    "形而上学基本问题": {
      "description": "本体论的核心问题域",
      "problems": {
        "一与多": {
          "question": "世界的本质是统一还是多元？",
          "positions": [
            "一元论",
            "二元论",
            "多元论"
          ],
          "significance": "关于世界统一性的根本问题"
        },
        "潜能与现实": {
          "distinction": "亚里士多德的核心区分",
          "potentiality": "事物可能达到但尚未实现的状态",
          "actuality": "事物已经实现的状态",
          "priority": "现实优先 vs 潜能优先"
        },
        "必然与偶然": {
          "question": "事物的存在是必然的还是偶然的？",
          "modal_realism": "可能世界的本体论地位",
          "applications": [
            "模态逻辑",
            "反事实分析"
          ]
        },
        "抽象对象": {
          "question": "数、集合、命题等抽象对象是否存在？",
          "positions": [
            "柏拉图主义",
            "唯名论",
            "虚构主义"
          ],
          "implications": "数学基础、语义学"
        }
      }
    }
  }
}